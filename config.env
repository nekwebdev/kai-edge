# repo-level defaults for the kai edge node bootstrap

# leave blank to use the invoking sudo user
KAI_USER=""

# leave blank to use the primary group for KAI_USER
KAI_GROUP=""

KAI_ROOT="/opt/kai"
KAI_APP_DIR="/opt/kai/app"
KAI_BIN_DIR="/opt/kai/bin"
KAI_CONFIG_DIR="/etc/kai"
KAI_STATE_DIR="/var/lib/kai"
KAI_LOG_DIR="/var/log/kai"

CREATE_VENV="1"
VENV_DIR="/opt/kai/venv"

# set to 0 if you do not want kai.local on the local lan
INSTALL_AVAHI="1"

# set to 1 to install/manage RaspAP during bootstrap
INSTALL_RASPAP="1"
RASPAP_INSTALL_URL="https://install.raspap.com"
# install minimally and non-interactively by default
RASPAP_INSTALL_FLAGS="--yes --openvpn 0 --wireguard 0 --adblock 0 --rest 0 --provider 0"
RASPAP_AP_SSID="Kai-Setup"
RASPAP_AP_PASSPHRASE="KaiSetup12345"
RASPAP_AP_SUBNET_CIDR="10.42.0.1/24"
RASPAP_AP_DHCP_RANGE="10.42.0.50,10.42.0.150,255.255.255.0,12h"
RASPAP_AP_DNS_SERVERS="1.1.1.1 8.8.8.8"
RASPAP_ENABLE_FALLBACK_AP="1"
RASPAP_ADMIN_USER="admin"
RASPAP_ADMIN_PASSWORD="kai-admin-change-this"

# set this before using kai-edge-trigger or kai-push-to-talk
KAI_CORE_BASE_URL=""

# one-shot runtime defaults written to /etc/kai/edge.env
KAI_RECORD_SECONDS="5"
KAI_AUDIO_SAMPLE_RATE="16000"
KAI_HTTP_TIMEOUT_SECONDS="60"

# daemon trigger mode:
# - manual: wait for explicit kai-edge-trigger socket command
# - vad: arm microphone and auto-capture utterances based on speech activity
# - wakeword: passively listen for a wake word, then capture one VAD-bounded utterance
KAI_TRIGGER_MODE="manual"
KAI_TRIGGER_SOCKET_PATH="/run/kai-edge/trigger.sock"

# wakeword tuning knobs (used when KAI_TRIGGER_MODE="wakeword")
# backend is currently fixed to porcupine
KAI_WAKEWORD_BACKEND="porcupine"
# required for porcupine backend
KAI_WAKEWORD_ACCESS_KEY=""
# use built-in keyword unless a custom keyword path is provided
KAI_WAKEWORD_BUILTIN_KEYWORD="porcupine"
# optional absolute path to a custom porcupine keyword model (.ppn)
KAI_WAKEWORD_KEYWORD_PATH=""
# optional absolute path to a porcupine model file (.pv)
KAI_WAKEWORD_MODEL_PATH=""
# porcupine sensitivity in [0.0, 1.0]
KAI_WAKEWORD_SENSITIVITY="0.5"
# cooldown after each wake detection before re-arming passive listener
KAI_WAKEWORD_DETECTION_COOLDOWN_MS="1500"
# timeout waiting for speech start after wake detection
KAI_WAKEWORD_POST_WAKE_SPEECH_TIMEOUT_MS="3000"

# vad tuning knobs (used in KAI_TRIGGER_MODE="vad" and post-wake utterance capture)
# aggressiveness: 0 (least strict) .. 3 (most strict)
KAI_VAD_AGGRESSIVENESS="3"
# frame size in milliseconds (must be 10, 20, or 30)
KAI_VAD_FRAME_MS="30"
# include a short pre-roll before speech start
KAI_VAD_PRE_ROLL_MS="250"
# reject clips with less than this much detected speech
KAI_VAD_MIN_SPEECH_MS="1200"
# reject clips unless one continuous speech run reaches this duration
KAI_VAD_MIN_SPEECH_RUN_MS="900"
# stop recording after this much trailing silence
KAI_VAD_TRAILING_SILENCE_MS="700"
# hard stop so recording cannot run forever
KAI_VAD_MAX_UTTERANCE_MS="10000"
# cooldown before re-arming after each utterance
KAI_VAD_COOLDOWN_MS="400"
# fallback threshold when webrtcvad is unavailable
KAI_VAD_ENERGY_THRESHOLD="260"

# observability summary cadence:
# - set seconds to 0 to disable time-based summary emission
# - set interactions to 0 to disable interaction-count summary emission
KAI_OBS_SUMMARY_INTERVAL_SECONDS="300"
KAI_OBS_SUMMARY_INTERVAL_INTERACTIONS="10"

# runtime status artifact for kai-edge-status and kai-doctor
KAI_OBS_STATUS_FILE_ENABLED="1"
KAI_OBS_STATUS_FILE_PATH="/run/kai-edge/status.json"

# managed host-level logging retention controls
MANAGE_JOURNALD_RETENTION="1"
JOURNALD_SYSTEM_MAX_USE="200M"
JOURNALD_RUNTIME_MAX_USE="64M"
JOURNALD_MAX_FILE_SEC="7day"

# rotate optional file logs under KAI_LOG_DIR/*.log if they are used
MANAGE_KAI_LOGROTATE="1"

# install the runtime daemon service but keep it disabled by default
# set to 1 when you want bootstrap to enable and start kai-edge.service
ENABLE_KAI_EDGE_SERVICE="0"

# USB conference device on kai (EMEET OfficeCore M0 Plus)
KAI_RECORD_DEVICE="plughw:CARD=Plus,DEV=0"
KAI_PLAYBACK_DEVICE="plughw:CARD=Plus,DEV=0"

# space-separated extra packages if the pi-side service needs more later
APT_PACKAGES_EXTRA=""
