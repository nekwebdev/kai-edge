# repo-level defaults for the kai edge node bootstrap

# leave blank to use the invoking sudo user
KAI_USER=""

# leave blank to use the primary group for KAI_USER
KAI_GROUP=""

KAI_ROOT="/opt/kai"
KAI_APP_DIR="/opt/kai/app"
KAI_BIN_DIR="/opt/kai/bin"
KAI_CONFIG_DIR="/etc/kai"
KAI_STATE_DIR="/var/lib/kai"
KAI_LOG_DIR="/var/log/kai"

CREATE_VENV="1"
VENV_DIR="/opt/kai/venv"

# set to 0 if you do not want kai.local on the local lan
INSTALL_AVAHI="1"

# set to 1 to install/manage RaspAP during bootstrap
INSTALL_RASPAP="1"
RASPAP_INSTALL_URL="https://install.raspap.com"
# install minimally and non-interactively by default
RASPAP_INSTALL_FLAGS="--yes --openvpn 0 --wireguard 0 --adblock 0 --rest 0 --provider 0"
RASPAP_AP_SSID="Kai-Setup"
RASPAP_AP_PASSPHRASE="KaiSetup12345"
RASPAP_AP_SUBNET_CIDR="10.42.0.1/24"
RASPAP_AP_DHCP_RANGE="10.42.0.50,10.42.0.150,255.255.255.0,12h"
RASPAP_AP_DNS_SERVERS="1.1.1.1 8.8.8.8"
RASPAP_ENABLE_FALLBACK_AP="1"
RASPAP_ADMIN_USER="admin"
RASPAP_ADMIN_PASSWORD="kai-admin-change-this"

# set this before using kai-push-to-talk
KAI_CORE_BASE_URL=""

# one-shot runtime defaults written to /etc/kai/edge.env
KAI_RECORD_SECONDS="5"
KAI_AUDIO_SAMPLE_RATE="16000"
KAI_HTTP_TIMEOUT_SECONDS="60"

# USB conference device on kai (EMEET OfficeCore M0 Plus)
KAI_RECORD_DEVICE="plughw:CARD=Plus,DEV=0"
KAI_PLAYBACK_DEVICE="plughw:CARD=Plus,DEV=0"

# space-separated extra packages if the pi-side service needs more later
APT_PACKAGES_EXTRA=""
